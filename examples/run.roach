#!/usr/bin/env roach

include("include");

x = today("Monday");

puts(x);


//
// Now we'll append code to the file
//
let fh = open("slug.roach", "wa");
fh.write( "puts(\"A thing\\n\");" );
fh.write( "puts(\"One more thing\\n\");" );
fh.close()

//
// Run what we created.
//
run("slug");

remove("slug.roach");
