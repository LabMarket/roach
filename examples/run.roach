#!/usr/bin/env roach

//
// Now we'll append code to the file
//
let fh = open("slug.roach", "wa");
fh.write( "include(\"include\");\n");
fh.write( "puts(\"A thing\\n\");" );
fh.write( "puts(\"One more thing\\n\");" );
fh.close()

//
// Run what we created.
//
run("slug");

/*
    The function definded in `include.roach` is in the context
*/
puts(today("Sunday"));

remove("slug.roach");

/*
    function still available
*/
puts(today("Friday"));
